#!/usr/bin/env bash
# Wrapper script for the protoc-gen-pbtkurl plugin.
# protoc invokes this as a plugin; it reads CodeGeneratorRequest from stdin
# and writes CodeGeneratorResponse to stdout.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
JAR="$SCRIPT_DIR/plugin/build/libs/protoc-gen-pbtkurl.jar"

if ! command -v java &>/dev/null; then
  echo "protoc-gen-pbtkurl: error: 'java' not found on PATH" >&2
  exit 1
fi

if [ ! -f "$JAR" ]; then
  echo "protoc-gen-pbtkurl: error: plugin JAR not found at $JAR" >&2
  echo "  Run: ./gradlew :plugin:pbtkShadowJar" >&2
  exit 1
fi

if [ "${1:-}" = "--version" ]; then
  java -jar "$JAR" --version
  exit $?
fi

exec java -jar "$JAR" "$@"
